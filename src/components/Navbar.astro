---
const links = [
  { label: "Kategori", href: "#kategori" },
  { label: "Galeri", href: "#galeri" },
  { label: "Rasa", href: "#rasa" },
  { label: "Harga", href: "#harga" },
  { label: "Dessert Table", href: "#dessert-table" },
];
---

<header class="sticky top-0 z-50 h-16 bg-canvas/95 backdrop-blur border-b border-hairline">
  <div class="mx-auto flex h-full max-w-[1200px] items-center justify-between px-6">
    <a href="#" class="font-display text-xl text-ink" aria-label="Chère Cake Atelier — beranda">
      Chère <span class="text-primary">Cake Atelier</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a href={link.href} class="text-sm font-medium text-body hover:text-primary transition-colors">
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href="#konsultasi"
      class="hidden md:inline-flex h-10 items-center rounded-lg bg-primary px-5 text-sm font-medium text-canvas hover:bg-primary-active transition-colors"
    >
      Pesan Custom
    </a>

    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer h-10 w-10 flex items-center justify-center rounded-lg hover:bg-surface-card" aria-label="Buka menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M2 5h16M2 10h16M2 15h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </summary>
      <div class="absolute right-0 top-12 w-56 rounded-xl border border-hairline bg-canvas p-4 shadow-lg">
        <nav class="flex flex-col gap-3">
          {links.map((link) => (
            <a href={link.href} class="text-sm font-medium text-body hover:text-primary transition-colors">
              {link.label}
            </a>
          ))}
          <a
            href="#konsultasi"
            class="mt-2 inline-flex h-10 items-center justify-center rounded-lg bg-primary px-5 text-sm font-medium text-canvas hover:bg-primary-active transition-colors"
          >
            Pesan Custom
          </a>
        </nav>
      </div>
    </details>
  </div>
</header>
